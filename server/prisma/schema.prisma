generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("STAFF") // ADMIN | STAFF
  createdAt    DateTime @default(now())
}

// ─── MASTER PRODUCT LIBRARY ───────────────────────────────────────────────
model Product {
  id              String          @id @default(uuid())
  productCode     String          @unique
  layoutCode      String?
  description     String
  basePrice       Float           @default(0) // Added base price
  brandName       String?                      // Default brand for auto-fill
  listPrice       Float?                       // LP for auto-fill in quotation
  discountPercent Float?                       // Default discount %
  polarDiagramUrl String?
  productImageUrl String?

  // Stored as JSON strings for SQLite
  bodyColours      String @default("[]")
  reflectorColours String @default("[]")
  colourTemps      String @default("[]")
  beamAngles       String @default("[]")
  cri              String @default("[]")
  customAttributes String @default("[]")

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  quotationItems QuotationItem[]
}

// ─── CLIENTS ──────────────────────────────────────────────────────────────
model Client {
  id               String      @id @default(uuid())
  fullName         String
  companyName      String
  address          String
  city             String
  state            String
  pinCode          String
  mobileNumber     String
  emailId          String?
  companyGstNumber String?
  companyAddress   String?
  createdAt        DateTime    @default(now())
  quotations       Quotation[]
  payments         Payment[]

  // Dynamic customization
  customAttributes String      @default("[]") // JSON string: [{ key: "Birthdate", value: "..." }]
  customLabels     String?     // JSON string: { "fullName": "Contact Person" }
}

// ─── QUOTATIONS ────────────────────────────────────────────────────────────
model Quotation {
  id          String          @id @default(uuid())
  quoteNumber String          @unique
  quoteTitle  String
  projectName String
  city        String          @default("")
  state       String          @default("")
  validDays   Int             @default(30)
  gstRate     Float           @default(18)
  status      String          @default("DRAFT") // DRAFT | SENT | ACCEPTED | REJECTED | INVOICED
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id])
  createdById String
  notes         String?
  customLabels  String? // JSON: { "quoteTitle": "Site Title", "col_brand": "Make", ... }
  grandTotal  Float           @default(0)
  subtotal    Float           @default(0)
  gstAmount   Float           @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  lineItems QuotationItem[]
  payments  Payment[]
}

// ─── QUOTATION LINE ITEMS ──────────────────────────────────────────────────
model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  sno         Int
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])

  // Snapshot fields (copied from Product at quote creation time)
  productCode     String
  layoutCode      String?
  description     String
  basePrice       Float  @default(0) // Snapshot of price
  polarDiagramUrl String?
  productImageUrl String?
  bodyColours     String @default("[]")
  reflectorColours String @default("[]")
  colourTemps     String @default("[]")
  beamAngles      String @default("[]")
  cri             String @default("[]")

  unit String @default("NUMBERS") // NUMBERS | METERS

  // Up to 6 recommendation columns per row
  recommendations ItemRecommendation[]

  // Final working quotation selection
  finalBrandName   String?
  finalProductCode String?
  finalListPrice   Float?
  finalDiscount    Float?
  finalRate        Float?
  finalQuantity    Float?
  finalAmount      Float?
  finalMacadamStep String?
  finalUnit        String?
  customFields     String? // JSON storing dynamic custom columns values
}

// ─── RECOMMENDATION COLUMNS (A–F per line item) ────────────────────────────
model ItemRecommendation {
  id              String        @id @default(uuid())
  quotationItemId String
  quotationItem   QuotationItem @relation(fields: [quotationItemId], references: [id], onDelete: Cascade)
  label           String // "A" | "B" | "C" | "D" | "E" | "F"
  brandName       String
  productCode     String        @default("")
  listPrice       Float
  listPriceWithGst Float
  discountPercent Float
  rate            Float
  unit            String        @default("NUMBERS")
  quantity        Float
  amount          Float
  macadamStep     String        @default("")
}

// ─── PAYMENTS ─────────────────────────────────────────────────────────────
model Payment {
  id              String   @id @default(uuid())
  quotationId     String
  quotation       Quotation @relation(fields: [quotationId], references: [id])
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  amountPaid      Float
  paymentDate     DateTime
  paymentMethod   String // CASH | BANK_TRANSFER | UPI | CHEQUE
  referenceNumber String?
  notes           String?
  status          String   @default("COMPLETED") // COMPLETED | PENDING | PARTIAL
  createdAt       DateTime @default(now())
}

// ─── COMPANY SETTINGS (single row) ────────────────────────────────────────
model CompanySettings {
  id               String @id @default(uuid())
  companyName      String @default("Dam Lighting Solution LLP")
  tagline          String @default("design. allocate. maintain.")
  logoUrl          String?
  address          String @default("")
  phone            String @default("")
  email            String @default("")
  website          String @default("")
  gstNumber        String @default("")
  bankName         String @default("")
  accountName      String @default("")
  accountNumber    String @default("")
  ifscCode         String @default("")
  bankAddress      String @default("")
  currency         String @default("INR")
  defaultGst       Float  @default(18)
  defaultValidDays Int    @default(30)
  defaultTerms     String @default("")
}
